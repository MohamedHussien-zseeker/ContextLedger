+```python
+"""SQLite FTS5 search."""
+from memory.database import get_db
+from memory.crud import _row_to_memory
+
+
+def search(
+    vault_path,
+    q: str = "",
+    tags: list[str] | None = None,
+    type_filter: str = "",
+    source: str = "",
+    limit: int = 10,
+    offset: int = 0,
+) -> tuple[list, int]:
+    db = get_db(vault_path)
+    conditions = ["archived=0"]
+    params = []
+    if q:
+        conditions.append("memories_fts MATCH ?")
+        params.append(q)
+    if tags:
+        placeholders = ",".join("?" for _ in tags)
+        conditions.append(f"EXISTS (SELECT 1 FROM json_each(memories.tags) WHERE value IN ({placeholders}))")
+        params.extend(tags)
+    if type_filter:
+        conditions.append("type=?")
+        params.append(type_filter)
+    if source:
+        conditions.append("source=?")
+        params.append(source)
+    where = " AND ".join(conditions)
+    count = db.execute(f"SELECT COUNT(*) FROM memories WHERE {where}", params).fetchone()[0]
+    if q:
+        order = "ORDER BY rank"
+        rows = db.execute(
+            f"SELECT memories.* FROM memories JOIN memories_fts ON memories.rowid=memories_fts.rowid WHERE {where} {order} LIMIT ? OFFSET ?",
+            params + [limit, offset],
+        ).fetchall()
+    else:
+        rows = db.execute(
+            f"SELECT * FROM memories WHERE {where} ORDER BY updated_at DESC LIMIT ? OFFSET ?",
+            params + [limit, offset],
+        ).fetchall()
+    return [_row_to_memory(r) for r in rows], count
+
+
+def related(vault_path, mid: str, limit: int = 5) -> list:
+    db = get_db(vault_path)
+    rows = db.execute(
+        """SELECT m.* FROM memories m
+           JOIN memory_relationships r ON r.target_id = m.id
+           WHERE r.source_id=? AND m.archived=0
+           LIMIT ?""",
+        (mid, limit),
+    ).fetchall()
+    return [_row_to_memory(r) for r in rows]
+```
