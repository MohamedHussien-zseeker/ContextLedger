#!/usr/bin/env bash
set -euo pipefail

# ContextLedger context bridge for Termux
# Copies relevant memory context to clipboard for pasting into AI apps

VAULT="${MEMORY_VAULT:-$HOME/my-vault}"
HOST="${MEMORY_HOST:-127.0.0.1}"
PORT="${MEMORY_PORT:-9314}"
TOKEN_FILE="${MEMORY_TOKEN:-$HOME/.memory/token}"

usage() {
  cat <<EOF
Usage: cl-context [OPTIONS] "question or topic"

Search ContextLedger vault and copy context to clipboard.

Options:
  -v, --vault PATH    Vault path (default: ~/my-vault)
  -n, --limit N       Max results (default: 5)
  -t, --token FILE    Token file (default: ~/.memory/token)
  -h, --help          Show this help

Examples:
  cl-context "what did we decide about v0.1.3?"
  cl-context -n 10 "API design decisions"
  cl-context -v ~/other-vault "project status"
EOF
  exit 0
}

LIMIT=5

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage ;;
    -v|--vault) VAULT="$2"; shift 2 ;;
    -n|--limit) LIMIT="$2"; shift 2 ;;
    -t|--token) TOKEN_FILE="$2"; shift 2 ;;
    -*) echo "Unknown option: $1"; exit 1 ;;
    *) QUERY="$1"; shift ;;
  esac
done

if [[ -z "${QUERY:-}" ]]; then
  echo "Error: query required"
  echo "Usage: cl-context \"your question or topic\""
  exit 1
fi

if [[ ! -f "$TOKEN_FILE" ]]; then
  echo "Error: token file not found at $TOKEN_FILE"
  echo "Generate one: mkdir -p ~/.memory && openssl rand -hex 32 > $TOKEN_FILE"
  exit 1
fi

TOKEN=$(cat "$TOKEN_FILE")

# Check if server is running
if ! curl -sf "http://$HOST:$PORT/v1/health" >/dev/null 2>&1; then
  echo "Error: ContextLedger API not running at http://$HOST:$PORT"
  echo
  echo "Start it with:"
  echo "  MEMORY_VAULT=\"$VAULT\" memory serve --host $HOST --port $PORT"
  exit 1
fi

# Search
RESPONSE=$(curl -sf -H "Authorization: Bearer $TOKEN" \
  -H "Content-Type: application/json" \
  -d "{\"q\":\"$QUERY\",\"limit\":$LIMIT}" \
  "http://$HOST:$PORT/v1/search" 2>/dev/null)

if [[ -z "$RESPONSE" ]]; then
  echo "Error: search failed"
  exit 1
fi

# Format context
CONTEXT="## ContextLedger Memory Context

Query: $QUERY

### Results

"

# Parse results (handle both JSON array and empty results)
RESULTS=$(echo "$RESPONSE" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    items = data if isinstance(data, list) else data.get('results', [])
    for i, item in enumerate(items, 1):
        title = item.get('title', 'Untitled')
        score = item.get('score', 0)
        content = item.get('content', item.get('text', ''))
        # Truncate content
        if len(content) > 500:
            content = content[:500] + '...'
        print(f'#### {i}. {title} (score: {score:.2f})')
        print()
        print(content)
        print()
except Exception as e:
    print(f'Parse error: {e}')
    sys.exit(1)
" 2>/dev/null)

if [[ -z "$RESULTS" ]]; then
  CONTEXT+="No results found for: $QUERY"
else
  CONTEXT+="$RESULTS"
fi

CONTEXT+="
---
Paste this context into your AI app, then ask your question."

# Copy to clipboard
if command -v termux-clipboard-set >/dev/null 2>&1; then
  echo "$CONTEXT" | termux-clipboard-set
  echo "Context copied to clipboard. Paste into your AI app."
elif command -v xclip >/dev/null 2>&1; then
  echo "$CONTEXT" | xclip -selection clipboard
  echo "Context copied to clipboard. Paste into your AI app."
elif command -v xsel >/dev/null 2>&1; then
  echo "$CONTEXT" | xsel --clipboard --input
  echo "Context copied to clipboard. Paste into your AI app."
else
  echo "$CONTEXT"
  echo
  echo "(Install termux-clipboard-set for auto-copy: pkg install termux-api)"
fi